# Neon Postgres connection string (from the Vercel dashboard → Storage → Neon,
# or from neon.tech). When this is NOT set, the app falls back to a local JSON
# file at .data/matches.json so you can run it without a database during dev.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# football-data.org API token (free: https://www.football-data.org/client/register).
# Enables automatic score syncing from the live World Cup fixtures. If unset,
# the app simply stays manual-entry only.
FOOTBALL_DATA_TOKEN="your-token-here"
